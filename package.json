{
	"name": "quiz-board",
	"version": "0.4.0",
	"private": true,
	"author": {
		"name": "Avie",
		"url": "https://github.com/Avie0108"
	},
	"scripts": {
		"build-bg": "python backgrounds.py",
		"dev": "vite",
		"build": "run-p type-check \"build-only {@}\" --",
		"preview": "vite preview",
		"build-only": "pnpm build-bg && vite build",
		"type-check": "vue-tsc --noEmit -p tsconfig.app.json --composite false",
		"format": "pnpm exec prettier . --write",
		"prepare": "husky"
	},
	"dependencies": {
		"@vueuse/core": "^14.3.0",
		"pinia": "^3.0.4",
		"vue": "^3.5.39"
	},
	"repository": {
		"type": "git",
		"url": "github:Avie0108/QuizBoard"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@tsconfig/node24": "^24.0.4",
		"@types/node": "^26.0.1",
		"@vitejs/plugin-vue": "^6.0.7",
		"@vitejs/plugin-vue-jsx": "^5.1.6",
		"@vue/tsconfig": "^0.9.1",
		"eslint": "^10.6.0",
		"eslint-plugin-vue": "^10.9.2",
		"globals": "^17.7.0",
		"husky": "^9.1.7",
		"jiti": "^2.7.0",
		"lint-staged": "^17.0.8",
		"npm-run-all2": "^9.0.2",
		"prettier": "^3.9.4",
		"sass": "^1.101.0",
		"typescript": "~6.0.3",
		"typescript-eslint": "^8.62.1",
		"vite": "^8.1.0",
		"vite-plugin-vue-devtools": "^8.1.5",
		"vue-eslint-parser": "^10.4.1",
		"vue-tsc": "^3.3.5"
	},
	"lint-staged": {
		"*.{ts,vue}": ["eslint --fix", "prettier --write"]
	},
	"packageManager": "pnpm@11.9.0",
	"type": "module",
	"license": "MIT"
}
