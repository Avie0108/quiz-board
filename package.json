		"@vitejs/plugin-vue": "^6.0.4",
		"@vitejs/plugin-vue-jsx": "^5.1.4",
		"@vue/tsconfig": "^0.8.1",
		"eslint": "^10.0.0",
		"eslint-plugin-vue": "^10.7.0",
		"globals": "^17.3.0",
		"jiti": "^2.6.1",
